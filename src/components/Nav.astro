---
import { nav } from '../data/content';
---

<nav
  class="nav-anim-entrance sticky top-0 z-50 border-b border-ink/[0.09]"
  style="backdrop-filter:blur(10px);background:rgba(243,240,232,.82)"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between gap-6 px-6 py-4 md:px-10">
    <a
      href="#top"
      class="font-bricolage text-[22px] font-extrabold leading-none tracking-[-0.5px] text-ink no-underline"
    >
      NOEL S<span class="text-accent">.</span>
    </a>

    <div class="hidden items-center gap-[30px] md:flex">
      {nav.map((l) => (
        <a
          href={l.href}
          class="nav-link font-mono text-[12.5px] uppercase tracking-[1px] text-ink-secondary no-underline transition-colors duration-200 hover:text-accent"
        >
          {l.label}
        </a>
      ))}
    </div>

    <a
      href="#contact"
      class="hidden items-center gap-2 rounded-full bg-accent px-[22px] py-3 text-sm font-bold text-white no-underline transition-all duration-200 hover:-translate-y-0.5 hover:bg-ink md:inline-flex"
    >
      Book a Call →
    </a>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="flex flex-col gap-1.5 p-2 md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-ink"></span>
      <span class="block h-0.5 w-6 bg-ink"></span>
      <span class="block h-0.5 w-6 bg-ink"></span>
    </button>
  </div>

  <!-- Mobile nav — controlled via is-open class + CSS transition -->
  <div
    id="mobile-nav"
    class="gap-4 border-t border-ink/10 bg-cream px-[1.8rem] py-6 md:hidden"
  >
    {nav.map((l) => (
      <a
        href={l.href}
        class="nav-link font-mono text-[13px] uppercase tracking-[1px] text-ink-secondary no-underline"
      >
        {l.label}
      </a>
    ))}
    <a
      href="#contact"
      class="mt-2 inline-flex w-fit items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-bold text-white no-underline"
    >
      Book a Call →
    </a>
  </div>
</nav>

<script is:inline>
  // ── Mobile nav toggle ──────────────────────────────────────────────────
  var btn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-nav');
  if (btn && menu) {
    btn.addEventListener('click', function () {
      var open = btn.classList.contains('is-open');
      btn.classList.toggle('is-open', !open);
      menu.classList.toggle('is-open', !open);
      btn.setAttribute('aria-expanded', String(!open));
      btn.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    });
    menu.querySelectorAll('a').forEach(function (l) {
      l.addEventListener('click', function () {
        btn.classList.remove('is-open');
        menu.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Open menu');
      });
    });
  }

  // ── Active nav section tracker ─────────────────────────────────────────
  (function () {
    var sectionIds = ['about', 'work', 'gallery', 'services', 'contact'];
    var navLinks = document.querySelectorAll('.nav-link[href^="#"]');
    var currentActive = null;

    function getActiveSection() {
      var threshold = window.innerHeight * 0.42;
      var active = null;
      sectionIds.forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        var top = el.getBoundingClientRect().top;
        if (top <= threshold) active = id;
      });
      return active;
    }

    function updateNavActive() {
      var active = getActiveSection();
      if (active === currentActive) return;
      currentActive = active;
      navLinks.forEach(function (link) {
        var isActive = link.getAttribute('href') === '#' + active;
        link.classList.toggle('nav-active', isActive);
      });
    }

    window.addEventListener('scroll', function () {
      requestAnimationFrame(updateNavActive);
    }, { passive: true });

    updateNavActive();
  })();
</script>
