---
import { nav } from '../data/content';
---

<nav
  class="sticky top-0 z-50 border-b border-ink/[0.09]"
  style="backdrop-filter:blur(10px);background:rgba(243,240,232,.82)"
>
  <div class="mx-auto flex max-w-[1200px] items-center justify-between gap-6 px-6 py-4 md:px-10">
    <a
      href="#top"
      class="font-bricolage text-[22px] font-extrabold leading-none tracking-[-0.5px] text-ink no-underline"
    >
      NOEL S<span class="text-accent">.</span>
    </a>

    <div class="hidden items-center gap-[30px] md:flex">
      {nav.map((l) => (
        <a
          href={l.href}
          class="font-mono text-[12.5px] uppercase tracking-[1px] text-ink-secondary no-underline transition-colors duration-200 hover:text-accent"
        >
          {l.label}
        </a>
      ))}
    </div>

    <a
      href="#contact"
      class="hidden items-center gap-2 rounded-full bg-accent px-[22px] py-3 text-sm font-bold text-white no-underline transition-all duration-200 hover:-translate-y-0.5 hover:bg-ink md:inline-flex"
    >
      Book a Call →
    </a>

    <!-- Mobile hamburger placeholder -->
    <button
      id="mobile-menu-btn"
      class="flex flex-col gap-1.5 p-2 md:hidden"
      aria-label="Open menu"
    >
      <span class="block h-0.5 w-6 bg-ink"></span>
      <span class="block h-0.5 w-6 bg-ink"></span>
      <span class="block h-0.5 w-6 bg-ink"></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-nav"
    class="hidden flex-col gap-4 border-t border-ink/10 bg-cream px-10 py-6 md:hidden"
  >
    {nav.map((l) => (
      <a
        href={l.href}
        class="font-mono text-[13px] uppercase tracking-[1px] text-ink-secondary no-underline"
      >
        {l.label}
      </a>
    ))}
    <a
      href="#contact"
      class="mt-2 inline-flex w-fit items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-bold text-white no-underline"
    >
      Book a Call →
    </a>
  </div>
</nav>

<script is:inline>
  var btn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-nav');
  if (btn && menu) {
    btn.addEventListener('click', function () {
      menu.classList.toggle('hidden');
      menu.classList.toggle('flex');
    });
    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        menu.classList.add('hidden');
        menu.classList.remove('flex');
      });
    });
  }
</script>
