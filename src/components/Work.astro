---
import { caseStudies } from '../data/content';
---

<section
  id="work"
  class="mx-auto max-w-[1200px] px-10"
  style="padding-top:clamp(64px,8vw,120px);padding-bottom:clamp(32px,4vw,56px)"
>
  <div data-reveal class="mb-11 flex flex-wrap items-end justify-between gap-6">
    <div>
      <div class="mb-3.5 font-mono text-[12px] uppercase tracking-[2px] text-accent">
        05 — Selected work
      </div>
      <h2
        class="font-bricolage font-extrabold uppercase leading-[0.95] tracking-[-1px] text-ink"
        style="font-size:clamp(34px,4.6vw,60px);margin:0"
      >
        Problems, solved
      </h2>
    </div>
    <p class="max-w-[320px] text-[15px] text-muted-1" style="margin:0">
      Real engagements from 9 years of shipping. Each one framed as problem → approach → result.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    {caseStudies.map((cs, i) => (
      <div
        data-reveal
        style={`transition-delay: ${i * 80}ms`}
        class="flex flex-col rounded-[20px] border-[1.5px] border-ink/[0.12] bg-white p-[30px] transition-all duration-[250ms] hover:-translate-y-[6px] hover:border-accent hover:shadow-[0_20px_40px_rgba(22,21,15,0.1)]"
      >
        <div class="mb-1.5 flex items-start justify-between gap-4">
          <h3 class="font-bricolage text-[26px] font-extrabold tracking-[-0.4px] text-ink" style="margin:0">
            {cs.name}
          </h3>
          <span class="font-mono text-[16px] text-accent">↗</span>
        </div>
        <div class="mb-5 text-[14px] text-muted-1">{cs.role}</div>

        <div class="mb-[22px] flex flex-col gap-3.5">
          <div>
            <div class="mb-1 font-mono text-[10.5px] uppercase tracking-[1.5px] text-muted-3">Problem</div>
            <p class="text-[14.5px] leading-[1.55] text-ink-secondary" style="margin:0">{cs.problem}</p>
          </div>
          <div>
            <div class="mb-1 font-mono text-[10.5px] uppercase tracking-[1.5px] text-muted-3">Approach</div>
            <p class="text-[14.5px] leading-[1.55] text-ink-secondary" style="margin:0">{cs.approach}</p>
          </div>
          <div class="rounded-[12px] bg-cream p-3.5">
            <div class="mb-1 font-mono text-[10.5px] uppercase tracking-[1.5px] text-accent-dark">Result</div>
            <p class="text-[14.5px] font-semibold leading-[1.55] text-ink" style="margin:0">{cs.result}</p>
          </div>
        </div>

        <div class="mt-auto flex flex-wrap gap-2">
          {cs.tags.map((tag) => (
            <span class="rounded-full border border-ink/[0.16] px-[11px] py-[5px] font-mono text-[11px] text-ink-secondary">
              {tag}
            </span>
          ))}
        </div>
      </div>
    ))}

    <!-- Freelance placeholder -->
    <div
      data-reveal
      style="transition-delay: 160ms"
      class="col-span-1 flex flex-wrap items-center justify-between gap-6 rounded-[20px] border-2 border-dashed border-ink/[0.28] p-[34px] md:col-span-2"
    >
      <div>
        <div class="mb-2 font-mono text-[11px] uppercase tracking-[1.5px] text-muted-3">
          Freelance slot — fillable
        </div>
        <h3 class="font-bricolage text-[24px] font-extrabold text-ink" style="margin:0 0 6px">
          Your project could go here
        </h3>
        <p class="max-w-[520px] text-[14.5px] text-muted-1" style="margin:0">
          Reserved for freelance case studies — small-business sites, landing pages and SPAs. Send
          me the details and I'll drop them straight into this same problem → approach → result
          format.
        </p>
      </div>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-full bg-ink px-[22px] py-3.5 text-[14px] font-bold text-cream no-underline transition-all duration-200 hover:-translate-y-[3px]"
      >
        Start a project →
      </a>
    </div>
  </div>
</section>
