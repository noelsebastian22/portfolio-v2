---
import { aboutCols } from '../data/content';
---

<section
  id="about"
  class="mx-auto max-w-[1200px] px-10"
  style="padding-top:clamp(64px,8vw,120px);padding-bottom:clamp(64px,8vw,120px)"
>
  <div class="about-grid grid gap-12" style="grid-template-columns:minmax(0,1.2fr) minmax(0,0.8fr);align-items:start">

    <!-- LEFT: label → headline → bio → skills -->
    <div>
      <div data-reveal class="mb-5 font-mono text-[12px] uppercase tracking-[2px] text-accent-dark">
        03 — About
      </div>

      <h2
        data-reveal
        class="font-bricolage font-extrabold uppercase leading-[0.95] tracking-[-1px] text-ink"
        style="font-size:clamp(34px,4.6vw,60px);margin:0 0 clamp(28px,3vw,44px)"
      >
        Engineering rigour, for every audience
      </h2>

      <p data-reveal class="text-[17px] leading-[1.7] text-ink-secondary" style="margin:0 0 20px">
        I'm a Senior Web Engineer with 9+ years building high-scale frontend systems across
        Australia, the UK and India. I specialise in the modern Angular ecosystem — v20 signals, Nx
        monorepos and NgRx — and I obsess over the things users never see: performance budgets,
        accessibility, and test coverage that actually holds.
      </p>
      <p data-reveal class="text-[17px] leading-[1.7] text-ink-secondary" style="margin:0 0 36px">
        For companies that means enterprise architecture and measurable outcomes: 35% faster builds,
        400ms off First Contentful Paint, 90%+ coverage. For small businesses and tradies it means
        that same rigour applied to a fast, reliable site that brings in work. I also build in
        Next.js, Astro and Nuxt when the project calls for it.
      </p>

      <div data-reveal class="about-cols grid grid-cols-3 gap-[22px]">
        {aboutCols.map((col) => (
          <div>
            <div class="mb-3 border-b-2 border-ink pb-2.5 font-bricolage text-[16px] font-bold uppercase tracking-[0.3px]">
              {col.title}
            </div>
            {col.items.map((it) => (
              <div class="flex gap-2 py-[5px] text-[14px] text-ink-secondary">
                <span class="text-accent">▸</span>
                {it}
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <!-- RIGHT: portrait panel -->
    <div class="about-portrait">
      <picture data-reveal class="block">
        <source srcset="/images/portrait/portrait-400w.avif 400w, /images/portrait/portrait-800w.avif 800w" sizes="(max-width: 768px) 100vw, 45vw" type="image/avif" />
        <source srcset="/images/portrait/portrait-400w.webp 400w, /images/portrait/portrait-800w.webp 800w" sizes="(max-width: 768px) 100vw, 45vw" type="image/webp" />
        <img
          src="/images/portrait/portrait-800w.webp"
          alt="Noel Sebastian, Senior Web Engineer"
          width="800"
          height="800"
          loading="lazy"
          class="block h-auto w-full rounded-[18px] border-2 border-ink"
          style="box-shadow:14px 14px 0 rgba(22,21,15,.9)"
        />
      </picture>
    </div>

  </div>
</section>
