---
import { services } from '../data/content';
---

<section
  id="services"
  class="mx-auto max-w-[1200px] px-10"
  style="padding-top:clamp(64px,8vw,120px);padding-bottom:clamp(64px,8vw,120px)"
>
  <div data-reveal class="mb-11 flex flex-wrap items-end justify-between gap-6">
    <div>
      <div class="mb-3.5 font-mono text-[12px] uppercase tracking-[2px] text-accent-dark">
        06 — Freelance services
      </div>
      <h2
        class="font-bricolage font-extrabold uppercase leading-[0.95] tracking-[-1px] text-ink"
        style="font-size:clamp(34px,4.6vw,60px);margin:0"
      >
        What I build for clients
      </h2>
    </div>
    <p class="max-w-[320px] text-[15px] text-muted-1" style="margin:0">
      Enterprise engineering, right-sized for small businesses and tradies who need a site that works.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    {services.map((sv) => (
      <div
        data-reveal
        class="flex gap-[22px] rounded-[20px] border-[1.5px] border-ink/[0.12] bg-white p-8 transition-all duration-[250ms] hover:-translate-y-[5px] hover:border-accent hover:shadow-[0_18px_38px_rgba(22,21,15,0.09)]"
      >
        <div class="flex-none font-bricolage text-[34px] font-extrabold leading-none text-accent">
          {sv.no}
        </div>
        <div>
          <h3 class="font-bricolage text-[22px] font-bold text-ink" style="margin:0 0 10px">{sv.title}</h3>
          <p class="text-[15px] leading-[1.6] text-ink-secondary" style="margin:0">{sv.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>
