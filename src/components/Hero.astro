---
import { heroChips } from '../data/content';
---

<header class="mx-auto max-w-[1200px] px-10" style="padding-top:clamp(28px,3.5vw,56px);padding-bottom:clamp(24px,3vw,48px)">
  <div class="hero-grid grid items-center gap-14" style="grid-template-columns:minmax(0,1.15fr) minmax(0,0.85fr)">
    <!-- Left: text -->
    <div class="hero-text-col">
      <div
        class="hero-anim-status mb-[22px] inline-flex items-center gap-2.5 font-mono text-[12px] uppercase tracking-[2px] text-muted-1"
      >
        <span class="inline-block h-2 w-2 rounded-full bg-accent motion-safe:animate-blink"></span>
        Senior Web Engineer · Sydney, AU
      </div>

      <h1
        class="hero-anim-headline font-bricolage font-extrabold uppercase leading-[0.92] tracking-[-1.5px] text-ink"
        style="font-size:clamp(38px,6.2vw,82px);margin:0 0 24px"
      >
        Senior Web Engineer <span class="text-accent">&amp;</span> Angular Specialist
      </h1>

      <p
        class="hero-anim-body text-ink-secondary"
        style="font-size:clamp(16px,1.5vw,19px);line-height:1.65;max-width:520px;margin:0 0 34px"
      >
        I build high-scale frontends for companies — and fast, reliable websites for growing
        businesses. 9+ years, deep in the Angular ecosystem, and available for freelance.
      </p>

      <div class="hero-anim-cta mb-[34px] flex flex-wrap gap-3.5">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-4 text-[16px] font-bold text-white no-underline transition-all duration-200 hover:-translate-y-[3px] hover:bg-ink"
        >
          Book a Call →
        </a>
        <a
          href="#work"
          class="inline-flex items-center gap-2 rounded-full border-2 border-ink bg-transparent px-7 py-4 text-[16px] font-bold text-ink no-underline transition-all duration-200 hover:-translate-y-[3px] hover:bg-ink hover:text-cream"
        >
          See My Work
        </a>
      </div>

      <div class="flex flex-wrap gap-2.5">
        {heroChips.map((c, i) => (
          <span
            class="hero-anim-chip rounded-full border border-ink/[0.12] bg-white px-[13px] py-[7px] font-mono text-[11.5px] tracking-[0.5px] text-ink-secondary"
            style={`animation-delay: ${0.76 + i * 0.07}s`}
          >
            {c}
          </span>
        ))}
      </div>
    </div>

    <!-- Right: animated panel -->
    <div class="hero-anim-panel hero-panel relative" style="aspect-ratio:1/1.06;min-height:360px">
      <div class="hero-panel-inner absolute inset-0">
      <div
        class="absolute inset-0 overflow-hidden rounded-[22px] border-2 border-ink bg-yellow"
        style="box-shadow:14px 14px 0 rgba(22,21,15,.9)"
      >
        <!-- Spinning concentric rings -->
        <div
          class="absolute left-1/2 top-1/2 motion-safe:animate-spin-slow"
          style="width:118%;height:118%;transform:translate(-50%,-50%)"
        >
          <div class="absolute rounded-full border-2 border-ink/[0.14]" style="inset:8%"></div>
          <div class="absolute rounded-full border-2 border-ink/[0.14]" style="inset:20%"></div>
          <div class="absolute rounded-full border-2 border-dashed border-ink/[0.2]" style="inset:32%"></div>
        </div>

        <!-- Monogram -->
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
          <div
            class="font-bricolage font-extrabold leading-[0.82] tracking-[-4px] text-ink"
            style="font-size:clamp(90px,13vw,150px)"
          >
            NS
          </div>
          <div class="mt-1.5 font-mono text-[12px] uppercase tracking-[3px] text-ink">
            Est. 2016 · 9 yrs
          </div>
        </div>

        <!-- Orbiting dot -->
        <div
          class="absolute left-1/2 top-1/2 motion-safe:animate-orbit"
          style="width:74%;height:74%;transform:translate(-50%,-50%)"
        >
          <div
            class="absolute left-1/2 top-[-9px] h-[18px] w-[18px] -translate-x-1/2 rounded-full border-2 border-ink bg-accent"
          ></div>
        </div>

        <!-- Floating chips -->
        <span
          class="absolute left-3.5 top-3.5 rounded-full border border-yellow bg-ink px-[11px] py-1.5 font-mono text-[11px] font-bold text-yellow motion-safe:animate-floaty"
        >
          Angular v20
        </span>
        <span
          class="absolute bottom-4 right-3.5 rounded-full border-[1.5px] border-ink bg-white px-[11px] py-1.5 font-mono text-[11px] font-bold text-ink motion-safe:animate-floaty-b"
        >
          Nx · NgRx
        </span>
      </div>

      <!-- Rotating badge -->
      <div
        class="absolute flex items-center justify-center rounded-full bg-ink"
        style="bottom:-26px;left:-26px;width:118px;height:118px;box-shadow:0 10px 24px rgba(22,21,15,.25)"
      >
        <svg
          viewBox="0 0 200 200"
          class="absolute inset-0 h-full w-full motion-safe:animate-badge-spin"
        >
          <defs>
            <path
              id="badgePath"
              d="M100,100 m-74,0 a74,74 0 1,1 148,0 a74,74 0 1,1 -148,0"
            />
          </defs>
          <text
            class="font-mono text-[16px] font-bold"
            style="letter-spacing:5px;fill:#F3F0E8"
          >
            <textPath href="#badgePath">OPEN FOR FREELANCE • BOOK A CALL • </textPath>
          </text>
        </svg>
        <div class="h-3.5 w-3.5 rounded-full bg-accent"></div>
      </div>
      </div><!-- /hero-panel-inner -->
    </div>
  </div>
</header>
