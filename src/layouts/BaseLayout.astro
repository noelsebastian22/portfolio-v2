---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Noel Sebastian — Senior Web Engineer & Angular Specialist',
  description = 'I build high-scale frontends for companies — and fast, reliable websites for growing businesses. 9+ years, deep in the Angular ecosystem, and available for freelance.',
  ogImage = '/og-image.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Manrope:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Person -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Noel Sebastian",
        "jobTitle": "Senior Web Engineer & Angular Specialist",
        "url": "https://noelsebastian.dev",
        "sameAs": [
          "https://www.linkedin.com/in/noel-seban",
          "https://github.com/noelsebastian22",
          "https://medium.com/@noelsimc69"
        ],
        "email": "noelsimc69@gmail.com",
        "knowsAbout": ["Angular", "Frontend Engineering", "Web Performance", "Nx Monorepos", "NgRx", "TypeScript"],
        "workLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "Sydney", "addressCountry": "AU" } }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Noel Sebastian — Portfolio",
        "description": "Selected case studies and projects by Noel Sebastian, Senior Web Engineer & Angular Specialist.",
        "url": "https://noelsebastian.dev",
        "mainEntity": {
          "@type": "ItemList",
          "itemListElement": [
            { "@type": "Article", "name": "Winning Group", "url": "https://noelsebastian.dev", "description": "E-commerce frontend at scale — Angular v20, Nx monorepo migration." },
            { "@type": "Article", "name": "Direct Line Group", "url": "https://noelsebastian.dev", "description": "State architecture across 5+ apps — NgRx standardization." },
            { "@type": "Article", "name": "SRT Marine", "url": "https://noelsebastian.dev", "description": "Real-time marine control UI at 60fps." },
            { "@type": "Article", "name": "QBurst", "url": "https://noelsebastian.dev", "description": "Analytics dashboards with D3.js and sub-second latency." }
          ]
        }
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <div id="scroll-progress" aria-hidden="true"></div>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />

    <!-- Scroll-reveal: IntersectionObserver-based, zero scroll-event overhead -->
    <script is:inline>
      (function () {
        var reduce =
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduce) {
          document.querySelectorAll('[data-reveal]').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }

        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0, rootMargin: '0px 0px -48px 0px' });

        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('[data-reveal]').forEach(function (el) {
            io.observe(el);
          });
        });
      })();
    </script>

    <script is:inline>
      // ── Scroll progress bar ────────────────────────────────────────────────
      (function () {
        var bar = document.getElementById('scroll-progress');
        if (!bar) return;

        function updateProgress() {
          var scrollTop = window.scrollY;
          var docHeight = document.documentElement.scrollHeight - window.innerHeight;
          var progress = docHeight > 0 ? scrollTop / docHeight : 0;
          bar.style.transform = 'scaleX(' + Math.min(progress, 1) + ')';
        }

        window.addEventListener('scroll', function () {
          requestAnimationFrame(updateProgress);
        }, { passive: true });

        updateProgress();
      })();

      // ── Hero parallax ──────────────────────────────────────────────────────
      (function () {
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) return;

        if (window.matchMedia('(max-width: 767px)').matches) return;

        var panelInner = document.querySelector('.hero-panel-inner');
        var textCol = document.querySelector('.hero-text-col');
        var heroEl = document.querySelector('header');

        if (!panelInner && !textCol) return;

        function updateParallax() {
          var scrollY = window.scrollY;
          var heroHeight = heroEl ? heroEl.offsetHeight : 0;

          if (scrollY >= heroHeight + 80) {
            if (panelInner) panelInner.style.transform = '';
            if (textCol) textCol.style.transform = '';
            return;
          }

          if (panelInner) panelInner.style.transform = 'translateY(' + (-scrollY * 0.22) + 'px)';
          if (textCol) textCol.style.transform = 'translateY(' + (-scrollY * 0.1) + 'px)';
        }

        window.addEventListener('scroll', function () {
          requestAnimationFrame(updateParallax);
        }, { passive: true });
      })();
    </script>

  </body>
</html>
