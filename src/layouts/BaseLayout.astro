---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Noel Sebastian — Senior Web Engineer & Angular Specialist',
  description = 'I build high-scale frontends for companies — and fast, reliable websites for growing businesses. 9+ years, deep in the Angular ecosystem, and available for freelance.',
  ogImage = '/og-image.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Manrope:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: Person -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Noel Sebastian",
        "jobTitle": "Senior Web Engineer & Angular Specialist",
        "url": "https://noelsebastian.dev",
        "sameAs": [
          "https://www.linkedin.com/in/noel-seban",
          "https://github.com/noelsebastian22",
          "https://medium.com/@noelsimc69"
        ],
        "email": "noelsimc69@gmail.com",
        "knowsAbout": ["Angular", "Frontend Engineering", "Web Performance", "Nx Monorepos", "NgRx", "TypeScript"],
        "workLocation": { "@type": "Place", "address": { "@type": "PostalAddress", "addressLocality": "Sydney", "addressCountry": "AU" } }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "CollectionPage",
        "name": "Noel Sebastian — Portfolio",
        "description": "Selected case studies and projects by Noel Sebastian, Senior Web Engineer & Angular Specialist.",
        "url": "https://noelsebastian.dev",
        "mainEntity": {
          "@type": "ItemList",
          "itemListElement": [
            { "@type": "Article", "name": "Winning Group", "url": "https://noelsebastian.dev", "description": "E-commerce frontend at scale — Angular v20, Nx monorepo migration." },
            { "@type": "Article", "name": "Direct Line Group", "url": "https://noelsebastian.dev", "description": "State architecture across 5+ apps — NgRx standardization." },
            { "@type": "Article", "name": "SRT Marine", "url": "https://noelsebastian.dev", "description": "Real-time marine control UI at 60fps." },
            { "@type": "Article", "name": "QBurst", "url": "https://noelsebastian.dev", "description": "Analytics dashboards with D3.js and sub-second latency." }
          ]
        }
      }
    </script>

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />

    <!-- Scroll-reveal: observe [data-reveal] elements -->
    <script is:inline>
      (function () {
        var reduce =
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (reduce) {
          document.querySelectorAll('[data-reveal]').forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }

        var pending = [];

        function show(el) {
          el.classList.add('is-visible');
          pending = pending.filter(function (x) { return x !== el; });
        }

        function check() {
          var vh = window.innerHeight || document.documentElement.clientHeight;
          pending = pending.filter(function (el) {
            var r = el.getBoundingClientRect();
            if (r.top < vh * 0.92 && r.bottom > 0) {
              show(el);
              return false;
            }
            return true;
          });
        }

        document.addEventListener('DOMContentLoaded', function () {
          pending = Array.from(document.querySelectorAll('[data-reveal]'));
          check();
          requestAnimationFrame(check);
          var ticking = false;
          function onScroll() {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(function () { ticking = false; check(); });
          }
          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });
          setTimeout(function () {
            pending.slice().forEach(show);
          }, 1400);
        });
      })();
    </script>
  </body>
</html>
